# Application Settings
APP_NAME=AEGIS-AI Backend
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./aegis.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Simulation
SIMULATION_INTERVAL=1.0
SIMULATION_ENABLED=True

# Alert Settings
ALERT_ESCALATION_MINUTES=5
ALERT_AUTO_RESOLVE_HOURS=24

# AI Integration Endpoints
HELMET_AI_URL=http://localhost:5001
PPE_AI_URL=http://localhost:5002
PREDICTIVE_AI_URL=http://localhost:5003

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/aegis.log

# Report Settings
REPORT_OUTPUT_DIR=reports
